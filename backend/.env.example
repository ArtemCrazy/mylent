# Database (default for local Docker Postgres)
DATABASE_URL=postgresql+asyncpg://mylent:mylent@localhost:5432/mylent
DATABASE_URL_SYNC=postgresql://mylent:mylent@localhost:5432/mylent

# Auth
SECRET_KEY=your-secret-key-min-32-chars

# OpenAI (for AI pipeline)
OPENAI_API_KEY=

# Telegram (для скрипта импорта: python -m scripts.telegram_sync)
# Получить API ID и Hash: https://my.telegram.org -> API development tools
TELEGRAM_SESSION_PATH=./data/telegram_session
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional
DEBUG=false

# Продакшен: разрешённые домены для CORS (через запятую), например https://ваш-домен.ru
# CORS_ORIGINS=https://ваш-домен.ru,https://mylent.vercel.app
